{
  "extraKnownMarketplaces": {
    "muggle-works": {
      "autoUpdate": true,
      "source": {
        "source": "github",
        "repo": "multiplex-ai/muggle-ai-works"
      }
    }
  },
  "enabledPlugins": {
    "muggleai@muggle-works": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/ensure-muggle-plugin.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/scripts/check-skill-deps.mjs\" --hook",
            "statusMessage": "Checking skill dependency direction"
          }
        ]
      }
    ]
  }
}
