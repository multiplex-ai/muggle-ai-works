  "expected": {
    "preamble": "**Stage 8 — PR follow-up** — polling 1 PR(s), tick #1.",
    "items_seen": 1,
    "items_picked": [
      {
        "pr_key": "acme/widget#144",
        "type": "line_comment",
        "classification": "ambiguous",
        "outcome": "escalated",
        "reply_endpoint": null,
        "reply_body_contains": [],
        "commit_subject": null
      }
    ],
    "telemetry_events": [
