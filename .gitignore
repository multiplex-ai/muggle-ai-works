packages/**/src/**/*.d.ts
packages/**/src/**/*.d.ts.map
src/**/*.d.ts
src/**/*.d.ts.map

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Coverage
coverage/

# Environment
.env
.env.local
.env.*.local

# Cache
.eslintcache
*.tsbuildinfo

# Turborepo cache
.turbo/
.worktrees

# muggle-do / pr-followup session state (runtime, never committed)
.muggle-do/

# Claude Code per-user local settings (settings.json is shared; .local is machine-specific)
.claude/settings.local.json
